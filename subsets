class Solution:
    def subsets(self, nums: List[int]) -> List[List[int]]:
        def generate(ind,subset,ans,nums):
            if(ind==len(nums)):
                ans.append(subset.copy())
                return
            subset.append(nums[ind])
            generate(ind+1,subset,ans,nums)
            subset.pop()
            generate(ind+1,subset,ans,nums)
        ind=0
        subset=[]
        ans=[]
        generate(ind,subset,ans,nums)
        return ans
